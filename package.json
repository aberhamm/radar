{
  "name": "repo-audit-delivery-agent",
  "version": "0.1.0",
  "description": "Agentic consulting tool that investigates headless CMS codebases and produces structured, scored delivery outputs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "repo-audit-delivery-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "pnpm --filter ./dashboard dev",
    "dev:watch": "tsc --watch --preserveWatchOutput",
    "analyze": "tsx src/index.ts analyze",
    "investigate": "tsx src/index.ts analyze",
    "dashboard": "tsx src/index.ts dashboard",
    "test": "vitest run",
    "test:unit": "vitest run test/tools/",
    "test:e2e": "vitest run test/e2e/ --timeout 60000",
    "test:watch": "vitest",
    "spike:portkey": "tsx scripts/portkey-verify.ts",
    "spike:pi": "tsx scripts/pi-verify.ts",
    "dashboard:dev": "cd dashboard && next dev --webpack --port 3000"
  },
  "keywords": [
    "agent",
    "consulting",
    "sitecore",
    "optimizely",
    "audit"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "pdfkit": "^0.18.0",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
