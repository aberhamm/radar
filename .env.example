# ──────────────────────────────────────────────────────────────
# Radar — Provider Configuration
# Copy this file to .env and uncomment ONE provider section.
# ──────────────────────────────────────────────────────────────

# ── Option 1: OpenAI (simplest — 2 vars) ─────────────────────
# PROVIDER_TYPE=openai
# OPENAI_API_KEY=sk-...
# AGENT_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini

# ── Option 2: Portkey AI Gateway (routes to Bedrock/Anthropic) ─
# PROVIDER_TYPE=portkey
# PORTKEY_API_KEY=your-portkey-api-key
# PORTKEY_BASE_URL=https://portkeygateway.example.com/v1
# PORTKEY_PROVIDER=@aws-bedrock-use2
# AGENT_MODEL=us.anthropic.claude-sonnet-4-6
# FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── Option 3: Azure OpenAI ───────────────────────────────────
# PROVIDER_TYPE=azure-openai
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments
# AGENT_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini

# ── Option 4: Generic (Ollama, Together, Groq, vLLM, etc.) ──
# PROVIDER_TYPE=generic
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=                # optional, leave blank for local Ollama
# AGENT_MODEL=llama3.1:70b
# FAST_MODEL=llama3.1:8b

# ── Optional: Web Search ─────────────────────────────────────
# SEARCH_ENGINE=brave
# SEARCH_API_KEY=your-brave-search-api-key
