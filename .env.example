# ──────────────────────────────────────────────────────────────
# Radar — Provider Configuration
# Copy this file to .env and uncomment ONE provider section.
# ──────────────────────────────────────────────────────────────

# ── Option 1: OpenAI (simplest — 2 vars) ─────────────────────
# PROVIDER_TYPE=openai
# OPENAI_API_KEY=sk-...
# AGENT_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini

# ── Option 2: Portkey AI Gateway (routes to Bedrock/Anthropic) ─
# PROVIDER_TYPE=portkey
# PORTKEY_API_KEY=your-portkey-api-key
# PORTKEY_BASE_URL=https://portkeygateway.example.com/v1
# PORTKEY_PROVIDER=@aws-bedrock-use2
# AGENT_MODEL=us.anthropic.claude-sonnet-4-6
# FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── Option 3: Azure OpenAI ───────────────────────────────────
# PROVIDER_TYPE=azure-openai
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments
# AGENT_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini

# ── Option 4: Generic (Ollama, Together, Groq, vLLM, etc.) ──
# PROVIDER_TYPE=generic
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=                # optional, leave blank for local Ollama
# AGENT_MODEL=llama3.1:70b
# FAST_MODEL=llama3.1:8b

# ── Optional: Web Search ─────────────────────────────────────
# Enables the web_search tool for live documentation lookups.
# Without this, the agent skips web search gracefully.
# SEARCH_ENGINE=brave
# SEARCH_API_KEY=your-brave-search-api-key

# ── Optional: GitHub Integration ─────────────────────────────
# Used by the dashboard "Create Issues" button and CI adapters.
# Generate a PAT at https://github.com/settings/tokens with
# `repo` scope (or `public_repo` for public repos only).
# GITHUB_TOKEN=ghp_...

# ── Optional: CI / CD ───────────────────────────────────────
# These are auto-set by GitHub Actions / Azure DevOps runners.
# Only set manually for local testing of CI features.
#
# GitHub Actions (auto-detected when GITHUB_ACTIONS=true):
#   GITHUB_ACTIONS=true         — enables GitHub CI adapter
#   GITHUB_TOKEN=               — set automatically by Actions
#   GITHUB_REPOSITORY=owner/repo
#   GITHUB_EVENT_PATH=          — path to event payload JSON
#   GITHUB_API_URL=             — defaults to https://api.github.com
#
# Azure DevOps (auto-detected when TF_BUILD=True):
#   TF_BUILD=True               — enables Azure DevOps CI adapter
#   SYSTEM_ACCESSTOKEN=         — pipeline OAuth token
#   SYSTEM_COLLECTIONURI=       — org URL
#   SYSTEM_TEAMPROJECT=         — project name
#   BUILD_REPOSITORY_ID=        — repo GUID

# ── Optional: Webhook Notifications ─────────────────────────
# Fire-and-forget POST to Slack, Teams, or any URL after each run.
# Payload includes repo, score, finding counts, duration, cost.
# WEBHOOK_URL=https://hooks.slack.com/services/...
